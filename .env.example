# Nilix — Environment Variables
# Copy this file to .env and set NIL_JWT_SECRET.
# The defaults below point to the built-in dev sandbox (dev/) — works out of the box.
# Change NIL_MENU_FILE and NIL_DB_FILE to point to your app when ready.

# ─── Menu & App ────────────────────────────────────────────────────────────────
NIL_MENU_FILE=dev/menu.xml
# NIL_APP_DIR is auto-derived from dirname(NIL_MENU_FILE) — override if needed
# NIL_APP_DIR=/path/to/your/app

# ─── Server ────────────────────────────────────────────────────────────────────
NIL_PORT=3000

# ─── Databases ─────────────────────────────────────────────────────────────────
NIL_DB_FILE=dev/dbase/dev.db
NIL_AUTH_DB=data/auth.db

# ─── Auth / JWT ─────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NIL_JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_256BIT_HEX_STRING
NIL_JWT_EXPIRY=8h

# ─── CORS ───────────────────────────────────────────────────────────────────────
# REQUERIDO en producción. Sin este valor, el servidor bloquea todos los orígenes
# externos (origin: false) y loguea un aviso al arrancar.
# Usá la IP o dominio desde donde acceden los browsers de tus usuarios.
# NIL_ALLOWED_ORIGIN=http://192.168.1.x:3000

# ─── TLS / HTTPS (opcional) ─────────────────────────────────────────────────────
# Ambas variables deben estar presentes para habilitar HTTPS (TLS 1.2+).
# NIL_TLS_CERT=/path/to/cert.pem
# NIL_TLS_KEY=/path/to/key.pem
